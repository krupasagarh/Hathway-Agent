# Copy this file to .env in this folder — never commit .env.
TELEGRAM_BOT_TOKEN=paste-bot-token-from-BotFather

HATHWAY_USER=
HATHWAY_PASS=

# Multi-operator (optional): JSON array of {"id":"…","user":"…","password":"…"}
